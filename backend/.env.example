# ============================================================
# FollowStocks — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ── Authentication ──────────────────────────────────────────
# REQUIRED in production. A long random string used to sign JWT tokens.
JWT_SECRET=
# Token lifetime in minutes (default: 1440 = 24 hours)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── OpenAI / LLM ───────────────────────────────────────────
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=

# ── Azure OpenAI (optional, used by Boursorama import) ─────
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_DEPLOYMENT=

# ── Boursorama Integration ─────────────────────────────────
# BOURSORAMA_LOGIN_URL=https://clients.boursobank.com/connexion/
# BOURSORAMA_IDENTIFIER=
# BOURSORAMA_STORAGE_DIR=./private/boursorama
# BOURSORAMA_DEBUG=false
# BOURSORAMA_BROWSER_USE_MODEL=

# ── Market Data & Caching ──────────────────────────────────
# AUTO_REFRESH_SECONDS=300
# AUTO_REFRESH_ENABLED=true
# CAC40_CACHE_TTL_SECONDS=1800
# SBF120_CACHE_TTL_SECONDS=1800

# ── Custom SBF120 Symbols (optional, comma-separated) ──────
# SBF120_SYMBOLS=

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all.
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173
